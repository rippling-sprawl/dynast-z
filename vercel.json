{
  "buildCommand": "python3 build.py",
  "redirects": [
    { "source": "/masters", "destination": "/golf/2026/masters", "statusCode": 301 },
    { "source": "/masters/:page", "destination": "/golf/2026/masters/:page", "statusCode": 301 },
    { "source": "/golf/:year/season", "destination": "/season/:year", "statusCode": 301 },
    { "source": "/league/:leagueId", "destination": "/league/:leagueId/scout", "statusCode": 302 }
  ],
  "rewrites": [
    { "source": "/", "destination": "/views/index.html" },
    { "source": "/odds", "destination": "/views/odds/index.html" },
    { "source": "/bets/audit", "destination": "/views/bets/audit.html" },
    { "source": "/bets/place", "destination": "/views/bets/place.html" },
    { "source": "/bets/history", "destination": "/views/bets/history.html" },
    { "source": "/bets/settle", "destination": "/views/bets/settle.html" },
    { "source": "/bets", "destination": "/views/bets/index.html" },
    { "source": "/football", "destination": "/views/home/football.html" },
    { "source": "/trade-calculator", "destination": "/views/tools/trade-calculator.html" },
    { "source": "/league/:leagueId/team/:rosterId", "destination": "/views/league/team.html" },
    { "source": "/league/:leagueId/trades", "destination": "/views/league/trades.html" },
    { "source": "/league/:leagueId/trades", "destination": "/views/league/league-trades.html" },
    { "source": "/league/:leagueId/power", "destination": "/views/league/power.html" },
    { "source": "/league/:leagueId/schedule", "destination": "/views/league/schedule.html" },
    { "source": "/league/:leagueId/scout", "destination": "/views/league/scout.html" },
    { "source": "/league/:leagueId/rosters", "destination": "/views/league/league.html" },
    { "source": "/account", "destination": "/views/home/account.html" },
    { "source": "/archive", "destination": "/views/home/archive.html" },
    { "source": "/season/:year", "destination": "/views/golf/season.html" },
    { "source": "/golf", "destination": "/views/home/golf-hub.html" },
    { "source": "/golf/:year", "destination": "/api/golf/:year" },
    { "source": "/golf/:year/:tournament/leaderboard", "destination": "/views/golf/leaderboard.html" },
    { "source": "/golf/:year/:tournament/select-golfers", "destination": "/views/golf/select-golfers.html" },
    { "source": "/golf/:year/:tournament/3-ball-results", "destination": "/views/golf/3-ball-results.html" },
    { "source": "/golf/:year/:tournament/3-ball-lookup", "destination": "/views/golf/3-ball-lookup.html" },
    { "source": "/golf/:year/:tournament/3-ball", "destination": "/views/golf/3-ball.html" },
    { "source": "/golf/:year/:tournament/group-results", "destination": "/views/golf/group-results.html" },
    { "source": "/golf/:year/:tournament/groups", "destination": "/views/golf/groups.html" },
    { "source": "/golf/:year/:tournament/ev-model", "destination": "/views/golf/ev-model.html" },
    { "source": "/golf/:year/:tournament", "destination": "/views/golf/hub.html" },
    { "source": "/acknowledgements", "destination": "/views/home/acknowledgements.html" },
    { "source": "/jane/jobs", "destination": "/views/jane/jobs.html" },
    { "source": "/jane/admin", "destination": "/views/jane/admin.html" },
    { "source": "/jane/asheville-rentals", "destination": "/views/jane/asheville-rentals.html" },
    { "source": "/jane", "destination": "/views/jane/index.html" },
    { "source": "/api/:path*", "destination": "/api/:path*" }
  ],
  "headers": [
    {
      "source": "/styles/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/scripts/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/views/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/data/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    }
  ]
}
