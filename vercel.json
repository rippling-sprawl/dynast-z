{
  "buildCommand": "python3 build.py",
  "redirects": [
    { "source": "/masters", "destination": "/golf/2026/masters", "statusCode": 301 },
    { "source": "/masters/:page", "destination": "/golf/2026/masters/:page", "statusCode": 301 },
    { "source": "/golf/:year", "destination": "/season/:year", "statusCode": 301 },
    { "source": "/golf/:year/season", "destination": "/season/:year", "statusCode": 301 }
  ],
  "rewrites": [
    { "source": "/", "destination": "/views/index.html" },
    { "source": "/trade-calculator", "destination": "/views/trade-calculator.html" },
    { "source": "/league/:leagueId/team/:rosterId", "destination": "/views/team.html" },
    { "source": "/league/:leagueId/new-trades", "destination": "/views/new-trades.html" },
    { "source": "/league/:leagueId/trades", "destination": "/views/league-trades.html" },
    { "source": "/league/:leagueId/power", "destination": "/views/league-power.html" },
    { "source": "/league/:leagueId", "destination": "/views/league.html" },
    { "source": "/account", "destination": "/views/account.html" },
    { "source": "/archive", "destination": "/views/archive.html" },
    { "source": "/season/:year", "destination": "/views/golf/season.html" },
    { "source": "/golf/:year/:tournament/leaderboard", "destination": "/views/golf/leaderboard.html" },
    { "source": "/golf/:year/:tournament/select-golfers", "destination": "/views/golf/select-golfers.html" },
    { "source": "/golf/:year/:tournament/3-ball-results", "destination": "/views/golf/3-ball-results.html" },
    { "source": "/golf/:year/:tournament/3-ball-lookup", "destination": "/views/golf/3-ball-lookup.html" },
    { "source": "/golf/:year/:tournament/3-ball", "destination": "/views/golf/3-ball.html" },
    { "source": "/golf/:year/:tournament/group-results", "destination": "/views/golf/group-results.html" },
    { "source": "/golf/:year/:tournament/groups", "destination": "/views/golf/groups.html" },
    { "source": "/golf/:year/:tournament/ev-model", "destination": "/views/golf/ev-model.html" },
    { "source": "/golf/:year/:tournament", "destination": "/views/golf/hub.html" },
    { "source": "/acknowledgements", "destination": "/views/acknowledgements.html" },
    { "source": "/api/:path*", "destination": "/api/:path*" }
  ],
  "headers": [
    {
      "source": "/styles/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/scripts/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/views/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/data/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    }
  ]
}
