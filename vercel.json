{
  "buildCommand": "python3 build.py",
  "rewrites": [
    { "source": "/", "destination": "/views/index.html" },
    { "source": "/trade-calculator", "destination": "/views/trade-calculator.html" },
    { "source": "/league/:leagueId/team/:rosterId", "destination": "/views/team.html" },
    { "source": "/league/:leagueId/new-trades", "destination": "/views/new-trades.html" },
    { "source": "/league/:leagueId/trades", "destination": "/views/league-trades.html" },
    { "source": "/league/:leagueId/power", "destination": "/views/league-power.html" },
    { "source": "/league/:leagueId", "destination": "/views/league.html" },
    { "source": "/account", "destination": "/views/account.html" },
    { "source": "/masters", "destination": "/views/masters/index.html" },
    { "source": "/masters/select-golfers", "destination": "/views/masters/select-golfers.html" },
    { "source": "/masters/3-ball-results", "destination": "/views/masters/3-ball-results.html" },
    { "source": "/masters/3-ball-lookup", "destination": "/views/masters/3-ball-lookup.html" },
    { "source": "/masters/group-results", "destination": "/views/masters/group-results.html" },
    { "source": "/masters/groups", "destination": "/views/masters/groups.html" },
    { "source": "/masters/3-ball", "destination": "/views/masters/3-ball.html" },
    { "source": "/masters/leaderboard", "destination": "/views/masters/leaderboard.html" },
    { "source": "/masters/ev-model", "destination": "/views/masters/ev-model.html" },
    { "source": "/api/:path*", "destination": "/api/:path*" }
  ],
  "headers": [
    {
      "source": "/styles/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/scripts/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/views/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
